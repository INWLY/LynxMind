# ===== LLM Model =====
# Required: API Key for your LLM provider
ARK_API_KEY=
# Optional: Model name (default: doubao-seed-2-0-pro-260215)
MODEL=
# Optional: Fallback model for grading tasks
GRADE_MODEL=
# Optional: Fast model for simple tasks
FAST_MODEL=
# Optional: API base URL (default: https://ark.cn-beijing.volces.com/api/v3)
BASE_URL=

# ===== Embedding (Dense Vector) =====
# Local dense embedding model (langchain_huggingface / sentence-transformers)
EMBEDDING_MODEL=
# Device: cpu or cuda
EMBEDDING_DEVICE=
# Dense embedding dimension (must match Qdrant collection schema)
DENSE_EMBEDDING_DIM=

# ===== Rerank (optional — degrades gracefully if unset) =====
RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

# ===== Vector Database (Milvus) =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# ===== BM25 Sparse Stats Persistence =====
# Default: data/bm25_state.json in project root
# BM25_STATE_PATH=
